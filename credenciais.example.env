# Credenciais para acesso ao Trino (Active Directory)
# LEGADO — este arquivo era usado pelo pipeline_local.py.
# A Cloud Function usa as variáveis TRINO_USER e TRINO_PASSWORD configuradas via gcloud.
#
# Para rodar o pipeline_local.py localmente (cenários especiais), exporte no shell:
#   export TRINO_USER=seu.usuario
#   export TRINO_PASSWORD=sua_senha_ad
#
# Ou defina aqui e use: source credenciais.env
TRINO_USER=seu.usuario
TRINO_PASSWORD=sua_senha_ad

# Credenciais GCP (opcional - só se não usar gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=caminho/para/service-account.json
